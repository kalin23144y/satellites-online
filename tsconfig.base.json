{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@libs/auth": ["libs/auth/src"],
      "@libs/database": ["libs/database/src"],
      "@libs/common": ["libs/common/src"]
    },
    "incremental": true,
    "strict": true,
    "skipLibCheck": true
  }
}
