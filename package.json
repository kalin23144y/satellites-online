{
  "name": "nest-pnpm-monorepo",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "client:dev": "pnpm --filter @apps/client run dev",
    "client:build": "pnpm --filter @apps/client run build",
    "client:start": "pnpm --filter @apps/client run start",
    "db:generate": "pnpm --filter @libs/database exec prisma generate",
    "db:migrate": "pnpm --filter @libs/database exec prisma migrate dev",
    "db:status": "pnpm --filter @libs/database exec prisma migrate status",
    "db:reset": "pnpm --filter @libs/database exec prisma migrate reset --force",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
