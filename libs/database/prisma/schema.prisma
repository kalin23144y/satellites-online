generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String @id @default(uuid()) @db.Uuid
  login    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  login    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  files     File[]
}

model File {
  id     String @id @default(uuid()) @db.Uuid
  name   String @default("")
  user   User   @relation(fields: [userId], references: [id])
  userId String @db.Uuid

  isActive Boolean @default(false)

  sattellites Satellite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Satellite {
  id      String @id @default(uuid())
  noradId Int
  name    String

  operator  String?
  country   Country? @relation(fields: [countryId], references: [id])
  countryId String?  @db.Uuid
  purpose   String?
  groupName String?

  orbitClass  String? // LEO / MEO / GEO
  inclination Float?
  periodMin   Float?
  altitudeKm  Float?

  tles TleRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  file   File?   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileId String? @db.Uuid

  @@index([countryId])
  @@index([purpose])
  @@index([orbitClass])
}

model Satcat {
  noradCatId     Int    @unique
  objectName     String
  objectId       String
  objectType     String
  opsStatusCode  String
  owner          String
  launchDate     String
  launchSite     String
  decayDate      String
  period         Int
  inclination    Int
  apogee         Int
  perigee        Int
  rcs            Float?
  dataStatusCode String
  orbitCenter    String
  orbitType      String
}

model TleRecord {
  id String @id @default(uuid())

  satelliteId String
  satellite   Satellite @relation(fields: [satelliteId], references: [id], onDelete: Cascade)

  line1 String
  line2 String

  epoch  DateTime?
  source String?

  createdAt DateTime @default(now())

  @@index([satelliteId])
}

model Country {
  id         String      @id @default(uuid()) @db.Uuid
  name       String?
  code       String      @unique
  color      String
  filePath   String?
  satellites Satellite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([name])
}
