generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String   @id @default(uuid()) @db.Uuid
  login    String   @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String   @id @default(uuid()) @db.Uuid
  login    String   @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
